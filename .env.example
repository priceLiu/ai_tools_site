# Copy to `.env.local` and fill in real values. Restart `pnpm dev` after changes.

# Supabase (Dashboard → Settings → API)
NEXT_PUBLIC_SUPABASE_URL=https://your-project.supabase.co
NEXT_PUBLIC_SUPABASE_ANON_KEY=your_anon_public_key

# Optional: 服务端（批量删除、首页 bundle 写入 Supabase Storage 快照等）；Vercel 建议配置
# SUPABASE_SERVICE_ROLE_KEY=your_service_role_secret

# 本地未跑 Storage 迁移或不想读快照时，设为 1 则首页每次走数据库
# HOME_BUNDLE_SNAPSHOT_DISABLE=1

# Optional: email confirmation redirect in local/dev (otherwise uses window.origin + /auth/callback)
# NEXT_PUBLIC_DEV_SUPABASE_REDIRECT_URL=http://localhost:3000/auth/callback

# 工具 Logo / 截图在提交表单中转为 Base64 存入数据库，无需对象存储配置。

# --- Neon-only（当前栈：数据 + 邮箱密码登录）---
# DATABASE_URL=postgresql://USER:PASSWORD@YOUR-POOLER.neon.tech/neondb?sslmode=require
#
# 必填：邮箱密码登录会话签名（≥32 字符）。未设置会登录失败。生成：openssl rand -base64 32
# AUTH_SECRET=
#
# 可选：本地 Neon HTTPS fetch 失败时设为 postgres（TCP）；生产默认可不写
# NEON_DRIVER=postgres
#
# 首次在 Neon 执行 SQL 建表（含 auth_credentials）：见 database.env.sample 或
# supabase/migrations/20260204120000_neon_auth_credentials.sql
