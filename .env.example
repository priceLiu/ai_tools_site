# Copy to `.env.local` and fill in real values. Restart `pnpm dev` after changes.

# Supabase (Dashboard → Settings → API)
NEXT_PUBLIC_SUPABASE_URL=https://your-project.supabase.co
NEXT_PUBLIC_SUPABASE_ANON_KEY=your_anon_public_key

# Optional: email confirmation redirect in local/dev (otherwise uses window.origin + /auth/callback)
# NEXT_PUBLIC_DEV_SUPABASE_REDIRECT_URL=http://localhost:3000/auth/callback

# 工具 Logo / 截图在提交表单中转为 Base64 存入数据库，无需对象存储配置。
