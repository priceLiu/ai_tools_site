# Copy needed lines into `.env.local` (never commit real passwords).

# ============ DATABASE_URL ============
# 必填：PostgreSQL 连接串。`postgres` 包通过 TCP 连接（CloudBase Run / 本地 dev / Vercel Node serverless 都用同一份）。
#
# 腾讯云 TDSQL-C PostgreSQL（VPC 内网，CloudBase Run 推荐）：
DATABASE_URL="postgresql://USER:PASSWORD@INTRANET-HOST:5432/postgres?sslmode=require"
#
# 腾讯云 TDSQL-C PostgreSQL（公网，仅迁移 / 本地调试用，记得关公网或用安全组限制）：
# DATABASE_URL="postgresql://USER:PASSWORD@PUBLIC-HOST:5432/postgres?sslmode=require"
#
# Neon（已退役；如需回滚保留这条作参考）：
# DATABASE_URL="postgresql://USER:PASSWORD@YOUR-POOLER.neon.tech/neondb?sslmode=require"
#
# 注意：密码若含 `@ # % & = ?` 等保留字符，必须 URL-encode 后再放进字符串。

# ============ AUTH_SECRET ============
# 必填：登录会话 Cookie（JWT）签名密钥；至少 32 字符。
# 生成：openssl rand -base64 32
AUTH_SECRET="在此处粘贴至少32个字符的随机字符串"

# ============ 历史变量（已废弃，部署时不要设置） ============
# 旧：NEON_DRIVER（曾用于切换 HTTP/TCP 驱动），现已统一 TCP，本变量被 lib/neon/sql.ts 忽略。
# 旧：NEXT_PUBLIC_SUPABASE_*（早期 Supabase 时代），代码已无引用。
