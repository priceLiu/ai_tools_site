# Copy needed lines into `.env.local` (never commit real passwords).
# REVERT: Delete DATABASE_URL from `.env.local` to remove Neon from config.

# Neon: require TLS (`sslmode=require`). Pooler host is typical for serverless.
# Omit `channel_binding=require` if your client library errors on it.
DATABASE_URL="postgresql://USER:PASSWORD@YOUR-POOLER.neon.tech/neondb?sslmode=require"
#
# 必填：登录会话 Cookie（JWT）签名用，长度至少 32。勿泄露、勿提交到 Git。
# 生成示例：openssl rand -base64 32
AUTH_SECRET="在此处粘贴至少32个字符的随机字符串"
#
# 可选：覆盖 Neon 驱动。未设置时 — 开发环境默认 TCP；生产默认 HTTPS（@neondatabase/serverless）。
# 强制 HTTPS：NEON_DRIVER=http | serverless | fetch | neon
# 强制 TCP：NEON_DRIVER=postgres | tcp
# NEON_DRIVER=postgres
#
# If dev shows "fetch failed" / NeonDbError: @neondatabase/serverless uses HTTPS, not local TCP.
# Fix: resume project in Neon console; try other connection string (pooler vs direct); disable VPN/proxy;
# if password contains @ # % etc., URL-encode it; check terminal: curl -I https://console.neon.tech
#
# Email/password login requires tables on Neon. In Neon SQL Editor, run the full file once:
#   supabase/migrations/20260204120000_neon_auth_credentials.sql
# (creates public.auth_credentials + public.app_kv; FK needs public.profiles to exist first.)
